# Aria — Track 2 · an interactive dream-world: a guide talks with you while the
# scene is generated as real images. Copy to .env. .env is gitignored.
#
# Aria needs a DashScope (Alibaba Model Studio) API key. ONE key powers BOTH:
#   • the Qwen brain (the guide's words + memory), and
#   • HappyHorse-1.0 text-to-video (every scene is a generated TALKING video —
#     1080p with lip-synced audio, the guide actually speaks the line on screen).
# A key is REQUIRED — Aria cannot run without one. Put it below once you have it.

# ── Qwen brain (OpenAI-compatible endpoint) ──────────────────────────────────
# International endpoint: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-flash
QWEN_EMBED_MODEL=text-embedding-v3

# ── HappyHorse-1.0 text-to-video (DashScope Model Studio) — every scene ──────
# Native DashScope endpoint (NOT the OpenAI-compatible one). Async: the engine
# creates a task and polls until the video (with audio) is ready. The video key
# defaults to QWEN_API_KEY above, so you only set the key once.
#   Model: happyhorse-1.0-t2v  ·  720p / 1080p, up to 15s, integrated lip-synced audio
#   Docs:  https://www.alibabacloud.com/help/en/model-studio/text-to-video-api-reference
ARIA_VIDEO_BASE_URL=https://dashscope-intl.aliyuncs.com
ARIA_VIDEO_MODEL=happyhorse-1.0-t2v
ARIA_VIDEO_RESOLUTION=1080P
ARIA_VIDEO_DURATION=6
ARIA_VIDEO_TIMEOUT=240
# Optional: a separate key for video. Leave blank to reuse QWEN_API_KEY.
ARIA_VIDEO_KEY=
# auto = generate video when a key is present | happyhorse = force | placeholder = fallback only
ARIA_VIDEO_MODE=auto

# ── Memory substrate (Cadran) ────────────────────────────────────────────────
KIOKU_STORE=py
KIOKU_SOCKET=/tmp/aria_kiokud.sock
KIOKU_DATA_DIR=./aria_data

# ── Database — Aria's OWN store, never shared with Kioku or Chorus ────────────
# Paste Aria's dedicated Neon Postgres DSN for durable memory; blank → local SQLite.
DATABASE_URL=
ARIA_DB=
