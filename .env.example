# Aria — Track 2 · live two-agent dialogue with memory + HappyHorse video.
# Copy to .env. .env is gitignored; no key is ever committed or logged.
#
# Qwen Cloud is the MAIN brain. The key can be left blank here — a user enters
# their own Qwen key in the Aria web UI, which is sent per-request as the
# X-Qwen-Key header, lives only in that browser tab, and is never persisted.

# ── Qwen Cloud (OpenAI-compatible) — the brain ───────────────────────────────
# International endpoint: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland endpoint:      https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-flash
QWEN_EMBED_MODEL=text-embedding-v3

# ── HappyHorse-1.0 video (text-to-video, synced audio) ───────────────────────
# The right-hand pane. If no key / unavailable, Aria shows a graceful placeholder
# (status + live captions) so the whole split-screen UI still works.
HAPPYHORSE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
HAPPYHORSE_API_KEY=
HAPPYHORSE_MODEL=happyhorse-1.0-t2v
# Drop to "placeholder" to force the no-video demo even when a key is present.
ARIA_VIDEO_MODE=auto

# ── Memory substrate (Cadran) ────────────────────────────────────────────────
KIOKU_STORE=py
KIOKU_SOCKET=/tmp/aria_kiokud.sock
KIOKU_DATA_DIR=./aria_data

# ── Database — Aria's OWN store, never shared with Kioku or Chorus ────────────
# Paste Aria's dedicated Neon Postgres DSN here for durable, cross-machine memory.
# Leave blank to fall back to a local SQLite file under aria_data/.
DATABASE_URL=
ARIA_DB=
