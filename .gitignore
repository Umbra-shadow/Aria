# secrets — never committed. .env is Qwen-only; .env.local holds personal
# overrides (e.g. a Gemini test key) and must never be committed. Only the
# Qwen-only .env.example is tracked.
.env
.env.*
!.env.example

# personal planning / notes — for me only, never deployed
*.private.md
PLAN.md
NOTES.md

